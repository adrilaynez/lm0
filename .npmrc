# @vercel/analytics declares an OPTIONAL peer on @sveltejs/kit, which npm 10 tries to
# satisfy and drags in vite@8 — conflicting with the vite@7 used by vitest. The svelte
# peer is irrelevant to this Next.js app. legacy-peer-deps keeps installs (local `npm i`
# and CI `npm ci`) consistent and unblocked without affecting runtime behavior.
legacy-peer-deps=true
