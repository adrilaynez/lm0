# ─────────────────────────────────────────────────────────────────────────────
# Environment variables for adrian-v2-web. Copy to `.env.local` and adjust.
# EVERY var here is OPTIONAL — the app builds and runs with sensible defaults,
# and every lab visualizer has a client-side simulation mode, so no backend or
# secrets are required to develop. NEXT_PUBLIC_* vars are exposed to the browser
# (do NOT put secrets in them).
# ─────────────────────────────────────────────────────────────────────────────

# Canonical site origin — used for SEO (canonical URLs, hreflang, sitemap, OG).
# Defaults to https://adrianlaynez.dev when unset.
NEXT_PUBLIC_SITE_URL=https://adrianlaynez.dev

# Backend (FastAPI + PyTorch) base URL for live model inference. Defaults to
# http://localhost:8000. In production, lab requests are proxied via the /api
# rewrite in next.config.mjs, so you usually don't need to set this.
NEXT_PUBLIC_LM_LAB_API_URL=http://localhost:8000

# Sentry DSN — error reporting is GATED behind this var. Leave it UNSET and
# Sentry is completely inert (never imported on the server, tree-shaken from the
# client bundle). Set it to turn error reporting on. Analytics (Vercel) needs no
# config and is inert off-Vercel.
# NEXT_PUBLIC_SENTRY_DSN=

# Set to "true" to emit a bundle-size report on `npm run build`.
# ANALYZE=true
